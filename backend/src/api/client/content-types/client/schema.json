{
  "kind": "collectionType",
  "collectionName": "clients",
  "info": {
    "singularName": "client",
    "pluralName": "clients",
    "displayName": "Client"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "client_id": {
      "type": "uid"
    },
    "company_name": {
      "type": "string"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phone_number": {
      "type": "biginteger"
    },
    "type": {
      "type": "string"
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "client_id"
    },
    "street": {
      "type": "string"
    },
    "number_floor": {
      "type": "string"
    },
    "postal_code": {
      "type": "biginteger"
    },
    "nif": {
      "type": "biginteger"
    }
  }
}
