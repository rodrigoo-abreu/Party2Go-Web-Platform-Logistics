      "type": "string"
    },
    "price": {
      "type": "decimal"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "badge": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "specs": {
      "type": "json"
    },
    "included": {
      "type": "json"
    },
    "availability": {
      "type": "string"
    },
    "minTime": {
      "type": "string"
    },
    "tags": {
      "type": "json"
    }
  }
