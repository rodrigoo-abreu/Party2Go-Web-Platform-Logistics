{
  "kind": "collectionType",
  "collectionName": "couriers",
  "info": {
    "singularName": "courier",
    "pluralName": "couriers",
    "displayName": "Courier"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "courier_id": {
      "type": "uid"
    },
    "first_name": {
      "type": "string"
    },
    "last_name": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "is_active": {
      "type": "boolean"
    },
    "orders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::order.order",
      "mappedBy": "courier_id"
    },
    "phone_number": {
      "type": "biginteger"
    },
    "messages": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::message.message",
      "mappedBy": "courier"
    },
    "vehicle": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::vehicle-id.vehicle-id",
      "inversedBy": "courier"
    }
  }
}
