{
  "kind": "collectionType",
  "collectionName": "delivery_proofs",
  "info": {
    "singularName": "delivery-proof",
    "pluralName": "delivery-proofs",
    "displayName": "Delivery Proof",
    "description": "Stores proof of delivery including location, photo, and signature."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "order": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::order.order"
    },
    "location": {
      "type": "json"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "signature": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
